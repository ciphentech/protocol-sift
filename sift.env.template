# Protocol SIFT — environment variables template
# Copied to ~/.claude/sift.env by install.sh.
# Edit ~/.claude/sift.env — do NOT edit this template directly.
#
# ~/.claude/sift.env is gitignored and machine-local.
# Do NOT add AWS credentials to this file if you share the machine.

# ── S3 audit log shipping ──────────────────────────────────────────────────────
export SIFT_S3_BUCKET=hackasans-correlator-dev-sift-ai-logs   # S3 bucket name
export SIFT_S3_REGION=us-west-2                                # AWS region
export SIFT_S3_PREFIX=sift-logs                                # S3 key prefix

# ── Agent model attribution ────────────────────────────────────────────────────
export SIFT_AGENT_MODEL=claude-sonnet-4-6

# ── AWS credentials (leave blank to use ~/.aws/credentials or instance profile) ─
# export AWS_ACCESS_KEY_ID=
# export AWS_SECRET_ACCESS_KEY=
# export AWS_SESSION_TOKEN=

# ── NIST NTP API key (optional — omitting falls back to insecure NTP) ──────────
# export NIST_API_KEY=
